    "stx"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/winsznx/stacks-utils.git"
  },
  "peerDependencies": {
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "~5.9.3",
    "zod": "^4.1.13"
  }
